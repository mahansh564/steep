# Copy to .env and fill in (optional: use real env vars instead; .env is loaded if present).
# Never commit .env.

# Anthropic (required for classification / composition)
ANTHROPIC_API_KEY=

# Optional model override (default is Claude Sonnet current in code)
# STEEP_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Telegram Bot API (required for Telegram delivery)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Repo root if CWD is elsewhere (optional)
# STEEP_REPO_ROOT=/path/to/steep

# gmail-send + gmail.readonly OAuth uses files in repo root by default:
# credentials.json  (Desktop app OAuth client from Google Cloud Console)
# token.json        (created on first `steep-digest gmail-auth`)
