# Copy to server as /etc/steep/digest.env (not committed). systemd: EnvironmentFile=

# Gmail OAuth (Desktop app JSON from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=/etc/steep/credentials.json
GMAIL_TOKEN_PATH=/var/lib/steep/token.json

# Allowlist YAML
ALLOWLIST_PATH=/etc/steep/allowlist.yaml

# Cursor / idempotency (last successful run high-water mark)
STATE_PATH=/var/lib/steep/state.json

# OpenAI (or-compatible base URL optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Digest email (RFC 5322 To address)
DIGEST_TO_EMAIL=you@gmail.com

# Optional: shown as display name in From (Gmail may still show your account)
# DIGEST_SUBJECT_PREFIX=Newsletter digest

# Dry run: 1 to fetch/classify/render but skip Gmail send + Telegram
# STEEP_DRY_RUN=0

# Max newsletter messages to process per run (after cursor filter)
# STEEP_MAX_MESSAGES=50

# Gmail list pagination cap (fetch up to this many ids before filtering by cursor)
# STEEP_LIST_CAP=500

# Optional: path to USER.md for "interesting for me" (overrides CWD / repo USER.md)
# STEEP_USER_MD_PATH=/etc/steep/USER.md
